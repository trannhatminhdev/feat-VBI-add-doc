{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "module": "ESNext",
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@components": ["./components"],
      "@components/*": ["./components/*"]
    }
  },
  "composite": true,
  "references": [
    {
      "path": "../../packages/vseed"
    },
    {
      "path": "../../packages/vquery"
    },
    {
      "path": "../../packages/vbi"
    },
    {
      "path": "../../practices/demo"
    },
    {
      "path": "../../practices/minimalist"
    },
    {
      "path": "../../practices/streamlined"
    },
    {
      "path": "../../practices/professional"
    }
  ],
  "include": ["docs", "components", "theme", "rspress.config.ts"],
  "mdx": {
    "checkMdx": true
  }
}
