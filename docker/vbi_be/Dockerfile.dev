# syntax=docker/dockerfile:1.7

FROM node:24.12.0-slim

RUN apt-get update -y && apt-get install -y --no-install-recommends openssl procps && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Enable pnpm
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

# Copy workspace config first
COPY .env.example .env package.json pnpm-lock.yaml pnpm-workspace.yaml ./

# Copy packages source code (needed for dependencies)
COPY packages/ packages/

# Copy app source code
COPY apps/vbi_be/ apps/vbi_be/
COPY docker/vbi_be/docker-entrypoint.dev.sh /app/docker-entrypoint.dev.sh

# Install all dependencies
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile

EXPOSE 3030 9229
EXPOSE 1234

RUN chmod +x /app/docker-entrypoint.dev.sh
ENTRYPOINT ["/app/docker-entrypoint.dev.sh"]
