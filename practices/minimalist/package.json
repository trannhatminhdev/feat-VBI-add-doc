    "@visactor/vseed": "workspace:*",
    "@visactor/vtable": "1.23.1",
    "antd": "6.1.3",
    "zustand": "5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@rsbuild/plugin-react": "^1.4.3",
    "@rslib/core": "0.20.3",
    "@rstest/adapter-rslib": "0.2.2",
    "@rstest/core": "0.8.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.8",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "happy-dom": "^20.3.3",
    "prettier": "^3.7.3",
    "react": "^19.2.3",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1"
