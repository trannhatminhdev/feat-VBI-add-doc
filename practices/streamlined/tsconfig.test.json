{
  "extends": "./tsconfig.json",
  "include": ["src", "tests/**/*", "tests/**/*.json"],
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "lib": ["ESNext", "DOM"],
    "types": ["@rstest/core/globals", "@testing-library/jest-dom"],
    "paths": {
      "src/*": ["./src/*"]
    }
  }
}
