{
  "name": "@visactor/vbi-react",
  "version": "0.1.2",
  "private": true,
  "license": "MIT",
  "homepage": "https://visactor.github.io/VBI",
  "bugs": "https://github.com/VisActor/VBI/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/VisActor/VBI",
    "directory": "packages/vbi-react"
  },
  "author": {
    "name": "VisActor",
    "url": "https://www.visactor.io/"
  },
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./components": {
      "source": "./src/components/index.ts",
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components.js",
      "require": "./dist/components.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch --no-clean",
    "format": "prettier --write .",
    "lint": "eslint . --cache",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:update": "vitest run --update",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@visactor/vbi": "workspace:*",
    "react": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "9.39.0",
    "@rslib/core": "0.16.1",
    "@testing-library/react": "16.3.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@visactor/vbi": "workspace:*",
    "@visactor/vseed": "workspace:*",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.39.0",
    "globals": "16.4.0",
    "happy-dom": "20.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.0",
    "vitest": "3.2.4"
  },
  "sideEffects": false
}
