{
  "datasetId": "select-aggregation-median",
  "description": "Select Median Example",
  "vquery": {
    "select": [
      {
        "field": "salary",
        "aggr": { "func": "median" },
        "alias": "salary_median"
      }
    ]
  },
  "dataset": [
    { "id": 1, "name": "Alice", "age": 25, "department": "HR", "salary": 5000 },
    { "id": 2, "name": "Bob", "age": 30, "department": "Engineering", "salary": 8000 },
    { "id": 3, "name": "Charlie", "age": 35, "department": "Engineering", "salary": 9000 },
    { "id": 4, "name": "David", "age": 40, "department": "HR", "salary": 6000 },
    { "id": 5, "name": "Eve", "age": 22, "department": "Marketing", "salary": 4000 },
    { "id": 6, "name": "Frank", "age": 28, "department": "Engineering", "salary": 7000 }
  ],
  "schema": [
    { "name": "id", "type": "number" },
    { "name": "name", "type": "string" },
    { "name": "age", "type": "number" },
    { "name": "department", "type": "string" },
    { "name": "salary", "type": "number" }
  ]
}
