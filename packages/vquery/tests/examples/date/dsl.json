{
  "dataset": {
    "id": "dateDataset",
    "schema": [
      { "name": "date", "type": "timestamp" },
      { "name": "sales", "type": "number" }
    ],
    "data": [
      { "date": "2025-01-01 10:30:45", "sales": 100 },
      { "date": "2025-01-01 11:15:00", "sales": 200 },
      { "date": "2025-01-02 09:00:00", "sales": 300 },
      { "date": "2025-02-01 10:00:00", "sales": 400 }
    ]
  },
  "cases": [
    {
      "name": "Year",
      "query": {
        "select": [
          { "field": "date", "func": "to_year", "alias": "year" },
          { "field": "sales", "func": "sum", "alias": "sales" }
        ],
        "groupBy": ["year"],
        "orderBy": [{ "field": "year", "order": "asc" }]
      },
      "assertions": [
        { "type": "length", "value": 1 },
        { "type": "value", "row": 0, "field": "sales", "value": 1000 },
        { "type": "datePart", "row": 0, "field": "year", "part": "year", "value": 2025 }
      ]
    },
    {
      "name": "Month",
      "query": {
        "select": [
          { "field": "date", "func": "to_month", "alias": "month" },
          { "field": "sales", "func": "sum", "alias": "sales" }
        ],
        "groupBy": ["month"],
        "orderBy": [{ "field": "month", "order": "asc" }]
      },
      "assertions": [
        { "type": "length", "value": 2 },
        { "type": "value", "row": 0, "field": "sales", "value": 600 },
        { "type": "datePart", "row": 0, "field": "month", "part": "month", "value": 0 }
      ]
    },
    {
      "name": "Day",
      "query": {
        "select": [
          { "field": "date", "func": "to_day", "alias": "day" },
          { "field": "sales", "func": "sum", "alias": "sales" }
        ],
        "groupBy": ["day"],
        "orderBy": [{ "field": "day", "order": "asc" }]
      },
      "assertions": [
        { "type": "length", "value": 3 },
        { "type": "value", "row": 0, "field": "sales", "value": 300 }
      ]
    },
    {
      "name": "Hour",
      "query": {
        "select": [
          { "field": "date", "func": "to_hour", "alias": "hour" },
          { "field": "sales", "func": "sum", "alias": "sales" }
        ],
        "groupBy": ["hour"],
        "orderBy": [{ "field": "hour", "order": "asc" }]
      },
      "assertions": [{ "type": "length", "value": 4 }]
    },
    {
      "name": "Minute",
      "query": {
        "select": [
          { "field": "date", "func": "to_minute", "alias": "minute" },
          { "field": "sales", "func": "sum", "alias": "sales" }
        ],
        "groupBy": ["minute"],
        "orderBy": [{ "field": "minute", "order": "asc" }]
      },
      "assertions": [{ "type": "length", "value": 4 }]
    },
    {
      "name": "Second",
      "query": {
        "select": [
          { "field": "date", "func": "to_second", "alias": "second" },
          { "field": "sales", "func": "sum", "alias": "sales" }
        ],
        "groupBy": ["second"],
        "orderBy": [{ "field": "second", "order": "asc" }]
      },
      "assertions": [{ "type": "length", "value": 4 }]
    },
    {
      "name": "Quarter",
      "query": {
        "select": [
          { "field": "date", "func": "to_quarter", "alias": "quarter" },
          { "field": "sales", "func": "sum", "alias": "sales" }
        ],
        "groupBy": ["quarter"],
        "orderBy": [{ "field": "quarter", "order": "asc" }]
      },
      "assertions": [
        { "type": "length", "value": 1 },
        { "type": "value", "row": 0, "field": "sales", "value": 1000 }
      ]
    },
    {
      "name": "Week",
      "query": {
        "select": [
          { "field": "date", "func": "to_week", "alias": "week" },
          { "field": "sales", "func": "sum", "alias": "sales" }
        ],
        "groupBy": ["week"],
        "orderBy": [{ "field": "week", "order": "asc" }]
      },
      "assertions": [{ "type": "length", "value": 2 }]
    }
  ]
}
