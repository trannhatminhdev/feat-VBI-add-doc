{
  "name": "add-where-filter",
  "description": "添加Where过滤条件",
  "schema": [
    {
      "name": "area",
      "type": "string"
    },
    {
      "name": "product_type",
      "type": "string"
    },
    {
      "name": "sales",
      "type": "number"
    }
  ],
  "dsl": {
    "chartType": "bar",
    "dimensions": [
      {
        "field": "area",
        "alias": "区域"
      }
    ],
    "measures": [
      {
        "field": "sales",
        "alias": "销售额",
        "encoding": "yAxis",
        "aggregate": {
          "func": "sum"
        }
      }
    ],
    "whereFilters": [],
    "limit": 20
  },
  "code": "const applyBuilder = (builder: VBIBuilder) => { builder.whereFilters.add('product_type', node => { node.setOperator('eq').setValue('办公用品'); }); }"
}
