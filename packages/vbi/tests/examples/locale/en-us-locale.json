{
  "name": "en-US-locale",
  "description": "英文 locale 测试",
  "schema": [
    {
      "name": "province",
      "type": "string"
    },
    {
      "name": "sales",
      "type": "number"
    }
  ],
  "dsl": {
    "chartType": "bar",
    "dimensions": [
      {
        "field": "province",
        "alias": "Province"
      }
    ],
    "measures": [
      {
        "field": "sales",
        "alias": "Sales",
        "encoding": "yAxis",
        "aggregate": {
          "func": "sum"
        }
      }
    ],
    "theme": "light",
    "locale": "en-US",
    "version": 1,
    "limit": 10,
    "whereFilter": {
      "id": "root",
      "op": "and",
      "conditions": []
    }
  },
  "code": "const applyBuilder = (builder: VBIChartBuilder) => {\n  const nextLocale = 'en-US'\n  if (builder.locale.getLocale() !== nextLocale) {\n    builder.locale.setLocale(nextLocale)\n  }\n}"
}
