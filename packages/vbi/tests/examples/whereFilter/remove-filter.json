{
  "name": "remove-filter-by-index",
  "description": "按索引移除过滤条件：移除第一个品类筛选，只保留区域条件",
  "schema": [
    {
      "name": "province",
      "type": "string"
    },
    {
      "name": "area",
      "type": "string"
    },
    {
      "name": "product_type",
      "type": "string"
    },
    {
      "name": "sales",
      "type": "number"
    }
  ],
  "dsl": {
    "chartType": "column",
    "dimensions": [
      {
        "field": "province",
        "alias": "省份"
      }
    ],
    "measures": [
      {
        "field": "sales",
        "alias": "销售额",
        "encoding": "yAxis",
        "aggregate": {
          "func": "sum"
        }
      }
    ],
    "limit": 20,
    "whereFilter": {
      "id": "root",
      "op": "and",
      "conditions": [
        {
          "id": "f-product",
          "field": "product_type",
          "op": "eq",
          "value": "办公用品"
        },
        {
          "id": "f-area",
          "field": "area",
          "op": "in",
          "value": ["华东", "华北", "中南"]
        }
      ]
    }
  },
  "code": "const applyBuilder = (builder: VBIBuilder) => {\n  builder.whereFilter.remove(0);\n}"
}
