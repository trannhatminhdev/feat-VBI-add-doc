{
  "name": "remove-measure",
  "description": "删除度量",
  "schema": [
    {
      "name": "product_type",
      "type": "string"
    },
    {
      "name": "sales",
      "type": "number"
    },
    {
      "name": "profit",
      "type": "number"
    }
  ],
  "dsl": {
    "chartType": "table",
    "dimensions": [],
    "measures": [
      {
        "field": "sales",
        "alias": "销售额",
        "aggregate": {
          "func": "sum"
        },
        "encoding": "yAxis"
      },
      {
        "field": "profit",
        "alias": "利润",
        "aggregate": {
          "func": "sum"
        },
        "encoding": "yAxis"
      }
    ],
    "limit": 20
  },
  "code": "const applyBuilder = (builder: VBIBuilder) => {\n  builder.measures.update('sales', n => n.setAlias('待移除的销售额'))\n  builder.measures.remove('sales')\n}"
}
