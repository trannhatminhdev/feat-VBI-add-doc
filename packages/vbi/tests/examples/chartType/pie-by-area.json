{
  "name": "pie-by-area",
  "description": "饼图 - 按区域销售占比",
  "schema": [
    { "name": "area", "type": "string" },
    { "name": "sales", "type": "number" }
  ],
  "dsl": {
    "chartType": "pie",
    "dimensions": [{ "field": "area", "alias": "区域" }],
    "measures": [{ "field": "sales", "alias": "销售额", "encoding": "size", "aggregate": { "func": "sum" } }],
    "limit": 50
  },
  "code": "const applyBuilder = (builder: VBIBuilder) => { builder.chartType.changeChartType('donut'); }"
}
