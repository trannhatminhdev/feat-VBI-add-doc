{
  "name": "bar-by-product-type",
  "description": "柱状图 - 按产品类型销售额",
  "schema": [
    { "name": "product_type", "type": "string" },
    { "name": "sales", "type": "number" }
  ],
  "dsl": {
    "chartType": "bar",
    "dimensions": [{ "field": "product_type", "alias": "产品类型" }],
    "measures": [{ "field": "sales", "alias": "销售额", "encoding": "xAxis", "aggregate": { "func": "sum" } }],
    "limit": 10
  },
  "code": "const applyBuilder = (builder: VBIChartBuilder) => { builder.chartType.changeChartType('column'); }"
}
