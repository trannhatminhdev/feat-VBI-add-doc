{
  "name": "rose-by-city",
  "description": "玫瑰图 - 按城市销售额",
  "schema": [
    { "name": "city", "type": "string" },
    { "name": "sales", "type": "number" }
  ],
  "dsl": {
    "chartType": "rose",
    "dimensions": [{ "field": "city", "alias": "城市" }],
    "measures": [{ "field": "sales", "alias": "销售额", "encoding": "size", "aggregate": { "func": "sum" } }],
    "limit": 10
  },
  "code": "const applyBuilder = (builder: VBIChartBuilder) => { builder.chartType.changeChartType('pie'); }"
}
