{
  "name": "chart-type-switching",
  "description": "Switch between line and bar chart types",
  "schema": [
    { "name": "year", "type": "string" },
    { "name": "sales", "type": "number" },
    { "name": "profit", "type": "number" }
  ],
  "dsl": {
    "chartType": "line",
    "dimensions": [{ "field": "year", "alias": "年份" }],
    "measures": [{ "field": "sales", "alias": "销售额", "encoding": "yAxis", "aggregate": { "func": "sum" } }]
  },
  "code": "const applyBuilder = (builder: VBIBuilder) => { builder.chartType.changeChartType('columnParallel'); }"
}
