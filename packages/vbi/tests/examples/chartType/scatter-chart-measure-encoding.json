{
  "name": "scatter-chart-measure-encoding",
  "description": "散点图度量编码 - 测试 measure-encoding.ts Scatter 图表类型",
  "schema": [
    { "name": "sales", "type": "number" },
    { "name": "profit", "type": "number" }
  ],
  "dsl": {
    "chartType": "scatter",
    "dimensions": [],
    "measures": [
      { "field": "sales", "alias": "销售额", "encoding": "xAxis" },
      { "field": "profit", "alias": "利润", "encoding": "yAxis" }
    ],
    "limit": 10
  },
  "code": "const applyBuilder = (builder: VBIChartBuilder) => { builder.chartType.changeChartType('scatter'); }"
}
