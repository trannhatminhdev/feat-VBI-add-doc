{
  "name": "pie-chart-measure-encoding",
  "description": "饼图度量编码 - 测试 measure-encoding.ts Pie 图表类型",
  "schema": [
    { "name": "product_type", "type": "string" },
    { "name": "sales", "type": "number" }
  ],
  "dsl": {
    "chartType": "pie",
    "dimensions": [{ "field": "product_type", "alias": "产品类型" }],
    "measures": [{ "field": "sales", "alias": "销售额", "encoding": "angle", "aggregate": { "func": "sum" } }],
    "limit": 10
  },
  "code": "const applyBuilder = (builder: VBIBuilder) => { builder.chartType.changeChartType('pie'); }"
}
