{
  "name": "line-chart",
  "description": "折线图 - 按省份销售额趋势",
  "schema": [
    { "name": "province", "type": "string" },
    { "name": "sales", "type": "number" },
    { "name": "profit", "type": "number" }
  ],
  "dsl": {
    "chartType": "line",
    "dimensions": [{ "field": "province", "alias": "省份" }],
    "measures": [{ "field": "sales", "alias": "销售额", "encoding": "yAxis", "aggregate": { "func": "sum" } }]
  },
  "code": "const applyBuilder = (builder: VBIBuilder) => { builder.chartType.changeChartType('area'); }"
}
