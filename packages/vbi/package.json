{
  "name": "@visactor/vbi",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch --no-clean",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "rstest",
    "test:update": "rstest --update",
    "test:coverage": "rstest --coverage && open coverage/index.html",
    "typecheck": "tsc --noEmit",
    "build:test": "node scripts/build-tests.mjs",
    "build:examples": "node scripts/build-examples.mjs",
    "build:api": "node scripts/build-api.mjs",
    "g": "pnpm run build:test && pnpm run build:examples && pnpm run build:api && pnpm run format"
  },
  "dependencies": {
    "zod": "4.0.17",
    "remeda": "2.28.0",
    "yjs": "13.6.28",
    "simple-statistics": "7.8.8",
    "@visactor/vseed": "workspace:*"
  },
  "peerDependencies": {
    "@visactor/vseed": "workspace:*"
  },
  "devDependencies": {
    "@visactor/vquery": "workspace:*",
    "@eslint/js": "9.39.0",
    "@rslib/core": "0.16.1",
    "@rstest/core": "0.8.3",
    "@types/node": "24.10.1",
    "eslint": "9.39.0",
    "globals": "16.4.0",
    "prettier": "3.6.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.0",
    "ts-morph": "26.0.0"
  }
}
