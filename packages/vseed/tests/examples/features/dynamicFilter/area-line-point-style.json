{
  "name": "area-line-point-style",
  "description": "",
  "vseed": {
    "chartType": "area",
    "dataset": [
      {
        "date": "2019",
        "profit": 10,
        "sales": 20,
        "count": 50
      },
      {
        "date": "2020",
        "profit": 35,
        "sales": 60,
        "count": 50
      },
      {
        "date": "2021",
        "profit": 30,
        "sales": 60,
        "count": 50
      },
      {
        "date": "2022",
        "profit": 50,
        "sales": 100,
        "count": 50
      },
      {
        "date": "2023",
        "profit": 40,
        "sales": 80,
        "count": 50
      }
    ],
    "lineStyle": {
      "dynamicFilter": {
        "type": "row-with-field",
        "code": "\n        return [{__row_index: 0, field: 'profit'}]\n        "
      },
      "lineColor": "red",
      "lineWidth": 2,
      "lineStyle": "solid"
    },
    "pointStyle": {
      "dynamicFilter": {
        "type": "row-with-field",
        "code": "\n        return data.filter(item => item.profit / item.sales > 0.5).map(v => ({\n          __row_index: v.__row_index,\n          field: 'profit'\n        }))\n        "
      },
      "pointColor": "red",
      "pointSize": 10
    },
    "dimensions": [
      {
        "id": "date",
        "alias": "日期"
      }
    ],
    "measures": [
      {
        "id": "profit",
        "alias": "利润"
      },
      {
        "id": "sales",
        "alias": "销售额"
      },
      {
        "id": "count",
        "alias": "数量"
      }
    ]
  }
}
