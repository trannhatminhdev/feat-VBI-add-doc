      { "category": "ABC", "subCategory": "Phones", "product": "Smartphone", "sales": 8000, "profit": 1200 },
      { "category": "XYZ", "subCategory": "Phones", "product": "Smartphone", "sales": 8000, "profit": 1200 }
    ],
    "dimensions": [
      { "id": "category", "alias": "Category", "encoding": "hierarchy" },
      { "id": "subCategory", "alias": "SubCategory", "encoding": "hierarchy" },
      { "id": "product", "alias": "Product", "encoding": "hierarchy" },
      { "id": "product", "alias": "Product", "encoding": "label" },
      { "id": "__MeaId__", "encoding": "label" },
      { "id": "__MeaId__", "encoding": "hierarchy" }
