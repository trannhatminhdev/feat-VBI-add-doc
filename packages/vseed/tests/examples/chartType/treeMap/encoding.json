{
  "name": "Encoding",
  "description": "A tree map chart, with 5 data points, each with a category, subCategory, product, sales, and profit. Encoding category, subCategory, product, sales, and profit as hierarchy, label, and size.",
  "vseed": {
    "chartType": "treeMap",
    "dataset": [
      { "category": "Electronics", "subCategory": "Computers", "product": "Laptop", "sales": 5000, "profit": 500 },
